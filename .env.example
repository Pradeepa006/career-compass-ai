# ============================================
# CareerCompass AI - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# DATABASE
# ============================================
POSTGRES_USER=careercompass
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=careercompass_db
DATABASE_URL=postgresql://careercompass:your_secure_password_here@localhost:5432/careercompass_db

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# SECURITY
# ============================================
SECRET_KEY=your-super-secret-key-minimum-32-chars-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# AI / GENERATIVE AI
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro

# ============================================
# FRONTEND URLS
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CareerCompass AI

# ============================================
# NEXTAUTH
# ============================================
NEXTAUTH_SECRET=your-nextauth-secret-key
NEXTAUTH_URL=http://localhost:3000

# ============================================
# GITHUB OAUTH (Optional)
# ============================================
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_API_TOKEN=your-github-personal-access-token

# ============================================
# GOOGLE OAUTH (Optional)
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# EMAIL (For notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@careercompassai.com
EMAILS_FROM_NAME=CareerCompass AI

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# STORAGE (For resume uploads)
# ============================================
STORAGE_TYPE=local
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=careercompass-uploads
AWS_REGION=us-east-1

# ============================================
# RAPID API (For job listings)
# ============================================
RAPIDAPI_KEY=your-rapidapi-key

# ============================================
# SENTRY (Error tracking)
# ============================================
SENTRY_DSN=your-sentry-dsn
